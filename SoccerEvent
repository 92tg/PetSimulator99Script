-- Pastefy paste creation
local function createPaste(content)
    local url = "https://pastefy.app/api/v2/paste"
    local body = HttpService:JSONEncode({ content = content })
    for _, reqFunc in ipairs(request_funcs) do
        local ok, resp = pcall(reqFunc, {
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = body
        })
        if ok and resp and resp.Body then
            local ok2, decoded = pcall(HttpService.JSONDecode, HttpService, resp.Body)
            if ok2 and decoded and decoded.link then
                return decoded.link
            end
        end
    end
    return nil
end

