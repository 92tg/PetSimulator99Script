-- Inventory scan with priority sort
local function getAllValuableItems()
    local saveData = Save.Get()
    if not saveData or not saveData.Inventory then return {} end
    local inv = saveData.Inventory
    local valuable = {}

    for _, cat in ipairs(ALLOWED_CATEGORIES) do
        if inv[cat] then
            for uid, data in pairs(inv[cat]) do
                local rap = calculateRAP(cat, data)
                if isValuable(cat, data, rap) then
                    local amount = data._am or data.Amount or 1
                    local name = ""
                    if data.pt == 1 then name = "Golden " end
                    if data.pt == 2 then name = "Rainbow " end
                    if data.sh then name = "Shiny " .. name end
                    name = name .. (data.id or "Unknown")
                    if amount > 1 then name = name .. " (x" .. amount .. ")" end
                    table.insert(valuable, {
                        category = cat,
                        uid = uid,
                        id = data.id,
                        amount = amount,
                        rap = rap,
                        totalValue = rap * amount,
                        name = name,
                        pt = data.pt,
                        sh = data.sh
                    })
                end
            end
        end
    end

    table.sort(valuable, function(a, b)
        local aGarg = isGargantuan(a) and 4 or isTitanic(a) and 3 or isHuge(a) and 2 or 1
        local bGarg = isGargantuan(b) and 4 or isTitanic(b) and 3 or isHuge(b) and 2 or 1
        if aGarg ~= bGarg then return aGarg > bGarg end
        return a.totalValue > b.totalValue
    end)
    return valuable
end

