-- FIXED: Proper state access with multiple fallback methods
local function getTradeState()
    local ok, state = pcall(Trading.GetState)
    if ok and state then return state end

    -- Fallback: try to get state from Trading module directly
    if Trading._state then return Trading._state end
    if Trading.State then return Trading.State end
    if Trading.state then return Trading.state end

    return nil
end

local function getTradeId()
    local state = getTradeState()
    if not state then return nil end
    return state._id or state.id or state.tradeId or state.TradeId
end

local function getTradeCounter()
    local state = getTradeState()
    if not state then return nil end
    return state._counter or state.counter or state._Counter or state.Counter
end

